# Chef AI Copilot — Environment Configuration
# Copy this file to .env and fill in your real API key.
# NEVER commit .env to version control.

# Provider: openai | claude | gemini | openrouter
VITE_AI_PROVIDER=openai

# Your API key
VITE_AI_API_KEY=your_openai_key_here

# OpenAI models: gpt-4o | gpt-4o-mini | gpt-4-turbo
# Claude models: claude-sonnet-4-6 | claude-opus-4-7
# Gemini models: gemini-1.5-pro | gemini-1.5-flash
VITE_AI_MODEL=gpt-4o-mini
